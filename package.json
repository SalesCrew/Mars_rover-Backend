{
  "name": "mars-rover-backend",
  "version": "1.0.0",
  "description": "Mars Rover Admin Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "dsgvo:audit": "powershell -ExecutionPolicy Bypass -File ./scripts/dsgvo-local-audit.ps1",
    "dsgvo:audit:static": "powershell -ExecutionPolicy Bypass -File ./scripts/dsgvo-local-audit.ps1 -SkipBuild"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.87.1",
    "archiver": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.3.0",
    "express": "^4.18.2",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
